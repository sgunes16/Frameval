FRAMEVAL_DB_PATH=./frameval.db
FRAMEVAL_GRADER_ADDR=localhost:50051
FRAMEVAL_PORT=8080
FRAMEVAL_SANDBOX_IMAGE=frameval-sandbox:local
FRAMEVAL_MAX_CONCURRENT=1
FRAMEVAL_TASKS_ROOT=./tasks
# Official Terminal-Bench repo: https://github.com/laude-institute/terminal-bench
# Frameval expects the local path to the repo's task directory.
FRAMEVAL_TERMINAL_BENCH_ROOT=./benchmarks/terminal-bench/original-tasks
# Official SWE-bench Lite dataset: https://huggingface.co/datasets/SWE-bench/SWE-bench_Lite
# Frameval expects a local JSON or JSONL export path.
FRAMEVAL_SWE_BENCH_PATH=./benchmarks/SWE-bench_Lite.jsonl
GRADER_PORT=50051
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
CURSOR_API_KEY=
FRAMEVAL_CURSOR_COMMAND=
FRAMEVAL_GEMINI_COMMAND=
FRAMEVAL_ENABLE_LLM_JUDGE=false
FRAMEVAL_ENABLE_SPEC_ADHERENCE=false
