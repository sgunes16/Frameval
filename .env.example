FRAMEVAL_DB_PATH=./frameval.db
FRAMEVAL_GRADER_ADDR=localhost:50051
FRAMEVAL_PORT=8080
FRAMEVAL_SANDBOX_IMAGE=frameval-sandbox:local
FRAMEVAL_MAX_CONCURRENT=1
FRAMEVAL_TASKS_ROOT=./tasks
GRADER_PORT=50051

# LLM provider keys (only what AgentDx pipeline actually consumes)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CURSOR_API_KEY=

# Executor command overrides (leave blank to use the bundled invocation)
FRAMEVAL_CURSOR_COMMAND=
FRAMEVAL_AIDER_COMMAND=

# Aider/Ollama configuration (defaults assume local Ollama on host)
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
AIDER_MODEL=openai/qwen2.5-coder:7b

# Optional grading stages (failure classifier lands in Story #22)
FRAMEVAL_ENABLE_LLM_JUDGE=false
